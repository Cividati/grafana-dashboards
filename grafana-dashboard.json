          {
            "expr": "hass_climate_current_temperature_celsius{entity=\"climate.ac_escritorio\"}",
            "legendFormat": "",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null},
                {"color": "green", "value": 20},
                {"color": "yellow", "value": 25},
                {"color": "red", "value": 28}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
