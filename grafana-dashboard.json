      {
        "id": 2,
        "type": "timeseries",
        "title": "Room Temperatures Over Time",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 1},
        "datasource": {"type": "prometheus", "uid": "ffmxjqyleyxhce"},
        "targets": [
          {
            "expr": "hass_climate_current_temperature_celsius",
            "legendFormat": "{{friendly_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "color": {"mode": "palette-classic"},
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        },
        "options": {
          "tooltip": {"mode": "multi", "sort": "none"},
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
