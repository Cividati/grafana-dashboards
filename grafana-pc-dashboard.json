{
  "dashboard": {
    "id": null,
    "uid": null,
    "title": "PC Monitoring",
    "tags": [
      "pc",
      "system"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 0,
    "refresh": "15s",
    "templating": {
      "list": [
        {
          "name": "datasource",
          "label": "Data Source",
          "type": "datasource",
          "query": "prometheus",
          "refresh": 1,
          "includeAll": false,
          "hide": 0,
          "current": {},
          "options": []
        },
        {
          "name": "instance",
          "label": "Instance",
          "type": "query",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "definition": "label_values(node_uname_info, instance)",
          "query": {
            "query": "label_values(node_uname_info, instance)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 2,
          "sort": 1,
          "includeAll": false,
          "hide": 0,
          "current": {}
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "row",
        "title": "CPU",
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "CPU Usage Over Time",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 1
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "(1 - avg(irate(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"}[2m]))) * 100",
            "legendFormat": "Overall",
            "refId": "A"
          },
          {
            "expr": "(1 - avg by (cpu) (irate(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"}[2m]))) * 100",
            "legendFormat": "Core {{cpu}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 5
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Overall"
              },
              "properties": [
                {
                  "id": "custom.lineWidth",
                  "value": 3
                },
                {
                  "id": "custom.fillOpacity",
                  "value": 20
                },
                {
                  "id": "color",
                  "value": {
                    "fixedColor": "orange",
                    "mode": "fixed"
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "CPU Usage",
        "gridPos": {
          "h": 4,
          "w": 24,
          "x": 0,
          "y": 9
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "(1 - avg(irate(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"}[2m]))) * 100",
            "legendFormat": "",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 60
                },
                {
                  "color": "red",
                  "value": 85
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "graphMode": "area",
          "colorMode": "background",
          "textMode": "auto"
        }
      },
