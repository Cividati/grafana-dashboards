          {
            "expr": "node_filesystem_size_bytes{instance=\"$instance\", fstype=~\"ext4|xfs|btrfs|vfat|ntfs\"}",
            "legendFormat": "Total",
            "refId": "A",
            "instant": true,
            "format": "table"
          },
          {
            "expr": "node_filesystem_size_bytes{instance=\"$instance\", fstype=~\"ext4|xfs|btrfs|vfat|ntfs\"} - node_filesystem_avail_bytes{instance=\"$instance\", fstype=~\"ext4|xfs|btrfs|vfat|ntfs\"}",
            "legendFormat": "Used",
            "refId": "B",
            "instant": true,
            "format": "table"
          },
          {
            "expr": "node_filesystem_avail_bytes{instance=\"$instance\", fstype=~\"ext4|xfs|btrfs|vfat|ntfs\"}",
            "legendFormat": "Free",
            "refId": "C",
            "instant": true,
            "format": "table"
          },
          {
            "expr": "(1 - node_filesystem_avail_bytes{instance=\"$instance\", fstype=~\"ext4|xfs|btrfs|vfat|ntfs\"} / node_filesystem_size_bytes{instance=\"$instance\", fstype=~\"ext4|xfs|btrfs|vfat|ntfs\"}) * 100",
            "legendFormat": "Use%",
            "refId": "D",
            "instant": true,
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "fstype": true,
                "instance": true,
                "job": true
              },
              "renameByName": {
                "Value #A": "Total",
                "Value #B": "Used",
                "Value #C": "Free",
                "Value #D": "Use %",
                "mountpoint": "Mount",
                "device": "Device"
              },
              "indexByName": {
                "mountpoint": 0,
                "device": 1,
                "Value #A": 2,
                "Value #B": 3,
                "Value #C": 4,
                "Value #D": 5
              }
            }
          }
        ],
